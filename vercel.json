{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(health|auth|expenses|budget|forecast|report|api|profile|uploads)(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*\\.(?:css|js|html|png|jpg|jpeg|gif|svg|ico|webp|json|map|txt))",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
